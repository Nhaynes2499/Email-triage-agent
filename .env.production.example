# Production template for Email-triage-agent
#
# Recommended:
# - store this file as .env on the server, not in git
# - place credentials/token files outside the repo directory
# - use a dedicated shared mailbox or delegated ops mailbox

# Core paths
GMAIL_CREDENTIALS_FILE=/opt/email-triage-agent/secrets/google-oauth-client.json
GMAIL_TOKEN_FILE=/opt/email-triage-agent/secrets/google-oauth-token.json
DATA_DIR=/var/lib/email-triage-agent
TRIAGE_DB_PATH=/var/lib/email-triage-agent/triage.db

# Gmail ingestion
# Start conservative, then tighten once you know the mailbox patterns.
GMAIL_QUERY=in:anywhere -category:promotions -category:social
BACKFILL_MAX_MESSAGES=20000
SYNC_PAGE_SIZE=250

# AI classification
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini
CLASSIFICATION_BODY_CHAR_LIMIT=5000

# Daily digest
DAILY_DIGEST_RECIPIENT=ops@example.com

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_DEFAULT_DAYS=7
DASHBOARD_DEFAULT_LIMIT=150

# SMTP delivery
SMTP_HOST=smtp.yourmailhost.com
SMTP_PORT=587
SMTP_USERNAME=ops@example.com
SMTP_PASSWORD=replace_me
SMTP_FROM=ops@example.com
SMTP_USE_TLS=true
