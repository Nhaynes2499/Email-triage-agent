# Core paths
# Keep credentials and token files outside the repo in production if possible.
GMAIL_CREDENTIALS_FILE=./credentials.json
GMAIL_TOKEN_FILE=./token.json
DATA_DIR=./data
TRIAGE_DB_PATH=./data/triage.db

# Gmail ingestion
# Example filters:
# GMAIL_QUERY=in:anywhere
# GMAIL_QUERY=in:anywhere from:(@client.com)
# GMAIL_QUERY=in:anywhere -category:promotions -category:social
GMAIL_QUERY=in:anywhere -category:promotions
BACKFILL_MAX_MESSAGES=20000
SYNC_PAGE_SIZE=250

# AI classification
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
CLASSIFICATION_BODY_CHAR_LIMIT=5000

# Daily digest
# Leave DAILY_DIGEST_RECIPIENT empty if you only want the digest printed/stored locally.
DAILY_DIGEST_RECIPIENT=

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_DEFAULT_DAYS=7
DASHBOARD_DEFAULT_LIMIT=100

# Optional SMTP delivery
# If these are unset, the digest will still be generated and saved in SQLite.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
